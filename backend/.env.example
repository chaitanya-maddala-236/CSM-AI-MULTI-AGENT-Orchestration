# ═══════════════════════════════════════════════════════════════════════
# CS Copilot — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ── AI Provider — paste ONE key (auto-detected) ─────────────────────
LLM_PROVIDER=auto
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional: override model
# OPENAI_MODEL=gpt-4o
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-1.5-pro

# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-32-char-random-string
APP_DEBUG=true
FRONTEND_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-32-char-random-string

# ── PostgreSQL (REQUIRED) ────────────────────────────────────────────
# docker-compose sets this automatically. For local dev, set your own:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cs_copilot

# ── Redis (optional — websockets & caching) ──────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB (optional — vector RAG; rules-based fallback if absent) ─
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── LangSmith Tracing (optional) ─────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=cs-copilot
